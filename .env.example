# .env.example for Maestro AI

# Webhook endpoint (receives artist check-ins & state change pings)
WEBHOOK_URL=http://localhost:5678/webhook/health-update

# Flask app port (default: 8080)
PORT=8080

# Flask secret key for sessions (set in production)
# SECRET_KEY=replace-with-random-secret

# LLM config (local Ollama is fastest for dev; set to 'anthropic' for cloud)
LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama2
# OLLAMA_NUM_CTX=4096
# OLLAMA_TIMEOUT_SECONDS=1800
# ANTHROPIC_API_KEY=sk-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Token for dashboard (optional, for prod use)
# MAESTRO_TOKEN=your-secret-here
# MAESTRO_DEV_MODE=0

# Shared secret for inbound webhooks
# WEBHOOK_SECRET=replace-with-shared-secret

# Premium features toggle (set to 'false' to run open core only)
PREMIUM_FEATURES_ENABLED=true

# Optional integration base URLs
# MAESTRO_BASE_URL=http://localhost:8080
# N8N_BASE_URL=http://localhost:5678
# N8N_WEBHOOK_URL=http://localhost:5678/webhook/health-update

# Optional local data path override for scripts
# MAESTRO_DATA_DIR=./data

# Optional service/API integrations
# GOOGLE_MAPS_API_KEY=...
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# INSTAGRAM_ACCESS_TOKEN=...
# INSTAGRAM_PAGE_ID_DEFAULT=...
# X_BEARER_TOKEN=...
# SPOTIFY_ACCESS_TOKEN=...
# ORCHARD_API_KEY=...

# Optional email notification settings (check-in/webhook scripts)
# SENDER_EMAIL=sender@example.com
# EMAIL_ADDRESS=recipient-or-login@example.com
# EMAIL_PASSWORD=app-password-or-secret
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=465

# Set log level (optional: DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Example: Enable other features
# FEATURE_X=true

# Add other key-value pairs as needed for prod or advanced agents