# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Local-only / not part of public demo
examples/
scripts/security/

# If you do not intend to make scripts a package:
scripts/__init__.py

# ── Local/private roster (never commit) ─────────────────────────────────────
data_private/

# ── Data (public-safe) ─────────────────────────────────────────────────────
# Ignore everything under data/ by default, then allow only curated demo inputs.
data/**
!data/**/
!data/**/.gitkeep

# Allow demo artist profiles + demo BRIDGE snapshots
!data/artists/*.json
!data/bridge/*.json

# Optional: allow demo metrics
!data/metrics/**
!data/metrics/**/

# Always ignore drafts / personal outputs even if under allowed dirs
data/checkin/

# Explicitly ignore sensitive context/config even if someone tries to add it
data/lr_records_context.json
data/brett_communication_profile.json
data/bridge_learnings.json
data/autopilot_config.json
data/autopilot_actions.log

# Ignore common generated output folders
data/atlas/
data/echo/
data/forge/
data/sage/
data/vinyl/
data/ai_conversations/
data/briefings/
data/manifests/
data/workflows/
data/metrics/labelgrid/

# ── Internal documents ───────────────────────
*.pdf
*.html
!templates/*.html

# ── .env.example is safe to commit ───────────
!.env.example

# ── OS ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Large files ──────────────────────────────
*.gguf
models/

# ── Logs ─────────────────────────────────────
*.log
logs/